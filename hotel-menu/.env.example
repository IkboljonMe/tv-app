# SQLite database file
DATABASE_URL="file:./dev.db"

# Auth — set strong values in production
ADMIN_PASSWORD="admin123"
POS_PASSWORD="kitchen123"
# Login emails for native apps (email + password sign-in)
ADMIN_EMAIL="admin@gmail.com"
POS_EMAIL="kitchen@gmail.com"
AUTH_SECRET="change-me-to-a-long-random-string-in-production"

# Base URL used when generating room QR codes (no trailing slash)
NEXT_PUBLIC_BASE_URL="http://localhost:3001"

# Auto-translation of menu items (en/ru/uz) via the Claude API.
# Without a key, new items are stored untranslated (source text in all languages).
ANTHROPIC_API_KEY=""
# Optional: override the translation model (default claude-opus-4-8).
# TRANSLATION_MODEL="claude-haiku-4-5"

# Fallback USD↔UZS rate used if the live FX lookup fails (approx UZS per 1 USD).
FX_FALLBACK_UZS_PER_USD="12900"

# Backend data API — hotel-menu persists through the shared backend (Postgres).
MENU_DATA_API_URL="http://localhost:3000/api/v1"
INTERNAL_API_KEY=""
