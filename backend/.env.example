# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://hoteltv:hoteltv@localhost:5432/hoteltv"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Minimum 64 characters
JWT_SECRET="CHANGE_ME_CHANGE_ME_CHANGE_ME_CHANGE_ME_CHANGE_ME_CHANGE_ME_CHANGE"

# ── Exely PMS ─────────────────────────────────────────────────────────────────
EXELY_WEBHOOK_SECRET="your-exely-shared-secret"

# ── OpenWeatherMap ────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY="your-openweathermap-api-key"

# ── Media storage (local disk / mounted volume — no external credentials) ───────
# Directory uploads are written to & served from at /media/<key>.
MEDIA_DIR="uploads"
# Public origin of this backend, used to build absolute media URLs. Leave empty to
# return relative /media/<key> URLs (fine when clients call this same backend).
PUBLIC_BASE_URL=""

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
