# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://hoteltv:hoteltv@localhost:5432/hoteltv"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Minimum 64 characters
JWT_SECRET="CHANGE_ME_CHANGE_ME_CHANGE_ME_CHANGE_ME_CHANGE_ME_CHANGE_ME_CHANGE"

# ── Exely PMS ─────────────────────────────────────────────────────────────────
EXELY_WEBHOOK_SECRET="your-exely-shared-secret"

# ── OpenWeatherMap ────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY="your-openweathermap-api-key"

# ── S3 / Media storage ────────────────────────────────────────────────────────
S3_ENDPOINT="https://s3.amazonaws.com"
S3_BUCKET="hoteltv-media"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_REGION="us-east-1"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
