generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hotel {
  id               String   @id @default(uuid())
  name             String   @db.VarChar(255)
  city             String   @db.VarChar(100)
  countryCode      String   @map("country_code") @db.Char(2)
  timezone         String   @db.VarChar(60)
  defaultLanguage  String   @default("en") @map("default_language") @db.VarChar(10)
  logoUrl          String?  @map("logo_url")
  createdAt        DateTime @default(now()) @map("created_at")

  rooms    Room[]
  services HotelService[]
  content  HotelContent[]

  @@map("hotels")
}

model Room {
  id          String     @id @default(uuid())
  hotelId     String     @map("hotel_id")
  roomNumber  String     @map("room_number") @db.VarChar(20)
  floor       Int?       @db.SmallInt
  deviceToken String     @unique @map("device_token") @db.VarChar(64)
  deviceType  DeviceType @map("device_type")
  backgroundUrl String?  @map("background_url")
  lastSeenAt  DateTime?  @map("last_seen_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  hotel  Hotel       @relation(fields: [hotelId], references: [id])
  guests RoomGuest[]

  @@unique([hotelId, roomNumber])
  @@map("rooms")
}

model RoomGuest {
  id                   String   @id @default(uuid())
  roomId               String   @map("room_id")
  exelyReservationId   String   @map("exely_reservation_id") @db.VarChar(64)
  guestFirstName       String   @map("guest_first_name") @db.VarChar(100)
  guestLastName        String   @map("guest_last_name") @db.VarChar(100)
  guestLanguage        String   @default("en") @map("guest_language") @db.VarChar(10)
  checkIn              DateTime @map("check_in") @db.Date
  checkOut             DateTime @map("check_out") @db.Date
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  room Room @relation(fields: [roomId], references: [id])

  @@map("room_guests")
}

model HotelService {
  id         String   @id @default(uuid())
  hotelId    String   @map("hotel_id")
  label      Json
  iconUrl    String?  @map("icon_url")
  sortOrder  Int      @default(0) @map("sort_order") @db.SmallInt
  available  Boolean  @default(true)
  deepLink   String?  @map("deep_link")
  createdAt  DateTime @default(now()) @map("created_at")

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@map("hotel_services")
}

model HotelContent {
  id           String      @id @default(uuid())
  hotelId      String      @map("hotel_id")
  contentType  ContentType @map("content_type")
  title        Json?
  body         Json?
  mediaUrl     String?     @map("media_url")
  active       Boolean     @default(true)
  displayFrom  DateTime?   @map("display_from")
  displayUntil DateTime?   @map("display_until")
  priority     String?     @default("info") @db.VarChar(20)
  createdAt    DateTime    @default(now()) @map("created_at")

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@map("hotel_content")
}

model WeatherCache {
  cityKey   String   @id @map("city_key") @db.VarChar(100)
  data      Json
  fetchedAt DateTime @map("fetched_at")

  @@map("weather_cache")
}

enum DeviceType {
  android_tv
  tizen

  @@map("device_type")
}

enum ContentType {
  background
  announcement
  menu_item
  promo

  @@map("content_type")
}

// ─────────────────────────────────────────────────────────────────────────────
// Hotel Menu (in-room dining) — mirrors hotel-menu/prisma/schema.prisma.
// These tables back the hotel-menu Next.js app, which now persists through the
// backend data API instead of its own SQLite file. i18n fields are stored as
// JSON strings (the app parses/stringifies them itself) to stay byte-compatible.
// MenuHotel/MenuRoom are named distinctly so they don't collide with the TV
// platform's Hotel/Room above; relation field names match hotel-menu exactly.
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id         String    @id @default(cuid())
  name       String
  sourceLang String    @default("en")
  nameI18n   String    @default("{}")
  sortOrder  Int       @default(0)
  products   Product[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("menu_categories")
}

model Product {
  id              String           @id @default(cuid())
  name            String
  description     String           @default("")
  sourceLang      String           @default("en")
  nameI18n        String           @default("{}")
  descI18n        String           @default("{}")
  price           Int
  imageUrl        String           @default("")
  available       Boolean          @default(true)
  sortOrder       Int              @default(0)
  categoryId      String
  category        Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  recommendations Recommendation[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([categoryId])
  @@map("menu_products")
}

model Recommendation {
  id        String   @id @default(cuid())
  dayOfWeek Int
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([dayOfWeek, productId])
  @@index([dayOfWeek])
  @@map("menu_recommendations")
}

model MenuHotel {
  id            String     @id @default(cuid())
  name          String
  slug          String     @unique
  floors        Int        @default(1)
  roomsPerFloor Int        @default(0)
  active        Boolean    @default(true)
  imageUrl      String     @default("")

  // Branding & guest-landing content (surfaced on the in-room web page).
  logoUrl        String @default("")
  tripadvisorUrl String @default("")
  googleMapsUrl  String @default("")
  yandexMapsUrl  String @default("")
  wifiName       String @default("")
  wifiPassword   String @default("")
  instagramUrl   String @default("")
  telegramUrl    String @default("")

  rooms         MenuRoom[]
  guests        MenuGuest[]
  requests      ServiceRequest[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("menu_hotels")
}

// Guest-raised service requests (alarm / reception / taxi) from the TV or the
// in-room web page. Surfaced live in the admin dashboard and forwarded to
// Telegram. status is a plain string (mirrors Order) — PENDING | ACKNOWLEDGED |
// RESOLVED | CANCELLED. type — ALARM | SERVICE | TAXI | RECEPTION | PROBLEM (extensible).
model ServiceRequest {
  id         String    @id @default(cuid())
  hotelId    String
  hotel      MenuHotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomNumber String
  guestName  String    @default("")
  type       String
  status     String    @default("PENDING")
  note       String    @default("")
  payload    String    @default("{}")
  source     String    @default("web")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([hotelId])
  @@index([status])
  @@index([createdAt])
  @@map("service_requests")
}

model MenuRoom {
  id        String    @id @default(cuid())
  hotelId   String
  hotel     MenuHotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  number    String
  name      String    @default("")
  floor     Int       @default(0)
  active    Boolean   @default(true)
  orders    Order[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([hotelId, number])
  @@index([hotelId])
  @@map("menu_rooms")
}

model Order {
  id        String      @id @default(cuid())
  roomId    String
  room      MenuRoom    @relation(fields: [roomId], references: [id])
  status    String      @default("PENDING")
  note      String      @default("")
  total     Int         @default(0)
  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([roomId])
  @@index([status])
  @@index([createdAt])
  @@map("menu_orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  price     Int
  quantity  Int     @default(1)

  @@index([orderId])
  @@map("menu_order_items")
}

// In-room guest stay. The TV reads this by hotel slug + room number to
// personalize the welcome screen (name) while the guest is checked in.
model MenuGuest {
  id          String   @id @default(cuid())
  hotelId     String
  hotel       MenuHotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomNumber       String
  fullName         String
  preferredLanguage String  @default("")
  checkIn          DateTime  @default(now())
  checkOut         DateTime
  createdAt        DateTime  @default(now())

  @@index([hotelId, roomNumber])
  @@map("menu_guests")
}
