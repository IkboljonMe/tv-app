<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns="http://tizen.org/ns/packages"
          api-version="6.5"
          package="com.hoteltv.launcher"
          version="1.0.0">
    <profile name="tv"/>
    <ui-application
        appid="com.hoteltv.launcher"
        exec="hotel_tv_launcher"
        type="flutter"
        multiple="false"
        taskmanage="true"
        launch_mode="single">
        <label>Hotel TV</label>
        <icon>hotel_tv_launcher.png</icon>
        <!-- Required for Samsung LYNK/VXT commercial TV deployment -->
        <metadata key="http://developer.samsung.com/tizen/metadata/preferenceADB"
                  value="true"/>
    </ui-application>
    <privileges>
        <privilege>http://tizen.org/privilege/internet</privilege>
        <privilege>http://tizen.org/privilege/display</privilege>
        <privilege>http://tizen.org/privilege/tv.inputdevice</privilege>
    </privileges>
</manifest>
